    "storages": {
        "dataset": "./dataset_schema.json",
        "keyValueStores": {
            "price-history": "./key_value_store_schema.json"
        }
    },
    "dockerfile": "../Dockerfile",
    "defaultMemoryMbytes": 2048,
    "minMemoryMbytes": 1024,
    "maxMemoryMbytes": 4096,
    "defaultRunOptions": {
        "build": "latest",
        "memoryMbytes": 2048,
        "timeoutSecs": 900
