# Copy to .env and fill in your values for local testing.
# .env is gitignored — never commit credentials.

# DataImpulse (or other) proxy — US routing recommended
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=10000
PROXY_USERNAME=your_username
PROXY_PASSWORD=your_password

# US routing (DataImpulse appends __cr.us automatically if not in username)
PROXY_COUNTRY=us
PROXY_POOL_SIZE=8

# eBay browser: chromium (default), firefox, or auto (Chromium first, Firefox fallback)
# EBAY_BROWSER=chromium

# Keep same proxy session on eBay retries (default on). Set 0 to rotate.
# EBAY_STICKY_PROXY=1

# Optional: ZenRows for experimental Walmart/Best Buy bypass (not in production tier)
# ZENROWS_API_KEY=your_zenrows_api_key
